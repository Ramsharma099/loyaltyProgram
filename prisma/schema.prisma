generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id                   Int      @id @default(autoincrement())
  shopDomain           String   @unique
  shopifyPlanName      String?
  isShopifyPlus        Boolean  @default(false)
  isPartnerDevelopment Boolean  @default(false)
  createdAt            DateTime @default(now())

  customers      Customer[]
  loyaltySetting LoyaltySetting?
}

model LoyaltySetting {
  id     Int  @id @default(autoincrement())
  shopId Int  @unique
  shop   Shop @relation(fields: [shopId], references: [id])

  signupBonusPoints         Int     @default(100)
  orderSpendAmount          Int     @default(100)
  orderSpendPoints          Int     @default(10)
  refundSpendAmount         Int     @default(100)
  refundSpendPoints         Int     @default(10)
  checkoutRedemptionEnabled Boolean @default(true)
  checkoutRewardLimit       Int     @default(10)
  preferredIntegration      String  @default("theme")
  redemptionRewards         String  @db.Text

  // Checkout UI Text Settings
  checkoutLoginMessage        String @db.Text
  checkoutDescription         String @db.Text
  checkoutRewardPrompt        String @db.Text
  checkoutRedeemButtonText    String @db.Text
  checkoutRedeemingText       String @db.Text
  checkoutPointsLabel         String @db.Text
  checkoutSelectRewardMsg     String @db.Text
  checkoutNotEnoughPtsMsg     String @db.Text
  checkoutDisabledMsg         String @db.Text
  checkoutRedemptionTitle     String @db.Text
  checkoutGiftCardMsg         String @db.Text
  checkoutDiscountMsg         String @db.Text
  checkoutErrorMsg            String @db.Text
  checkoutLoadingMsg          String @db.Text
  checkoutAvailableRewardsMsg String @db.Text

  // Customer Account UI Text Settings
  accountLoginMessage     String @db.Text
  accountBalanceTitle     String @db.Text
  accountAvailableLabel   String @db.Text
  accountCurrentBalance   String @db.Text
  accountLoadingText      String @db.Text
  accountRedeemingText    String @db.Text
  accountRedeemButtonText String @db.Text
  accountDisabledMsg      String @db.Text
  accountNotEnoughPtsMsg  String @db.Text
  accountGiftCardMsg      String @db.Text
  accountErrorMsg         String @db.Text
  accountConfigErrorMsg   String @db.Text

  // Iframe Widget UI Settings
  iframeEyebrow          String @db.Text
  iframeHeading          String @db.Text
  iframeLoggedOutMessage String @db.Text
  iframeLoginLabel       String @db.Text
  iframePointsTemplate   String @db.Text
  iframeRewardsHeading   String @db.Text
  iframeNoRewardsMessage String @db.Text
  iframeRedeemButtonText String @db.Text
  iframeAccentColor      String @default("#008060") @db.VarChar(20)
  iframeBackgroundColor  String @default("#ffffff") @db.VarChar(20)
  iframeForegroundColor  String @default("#202223") @db.VarChar(20)
  iframeBorderColor      String @default("#e3e5e8") @db.VarChar(20)
  iframeFontFamily       String @default("system") @db.VarChar(120)
  iframeFontSize         Int    @default(14)
  iframeCustomCss        String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id     Int  @id @default(autoincrement())
  shopId Int
  shop   Shop @relation(fields: [shopId], references: [id])

  shopifyCustomerId String
  name              String?
  email             String?
  loyaltyPoints     Int      @default(0)
  createdAt         DateTime @default(now())

  transactions       PointTransaction[]
  rewards            Reward[]
  rewardActivityLogs RewardActivityLog[]

  @@unique([shopId, shopifyCustomerId])
}

model PointTransaction {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  points          Int
  transactionType String
  reason          String?
  createdAt       DateTime @default(now())
}

model Reward {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  rewardCode      String  @unique
  discountAmount  Float
  rewardType      String  @default("discount")
  shopifyRewardId String?

  pointsUsed Int

  status String @default("active")

  expiresAt    DateTime?
  orderId      String?
  appliedAt    DateTime?
  failedReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs RewardActivityLog[]
}

model RewardActivityLog {
  id Int @id @default(autoincrement())

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  rewardId Int?
  reward   Reward? @relation(fields: [rewardId], references: [id])

  rewardCode   String?
  activityType String
  message      String? @db.Text
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([rewardId])
  @@index([rewardCode])
  @@index([activityType])
}

model WebhookLog {
  id        Int      @id @default(autoincrement())
  topic     String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}
