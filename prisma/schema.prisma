generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id                   Int      @id @default(autoincrement())
  shopDomain           String   @unique
  shopifyPlanName      String?
  isShopifyPlus        Boolean  @default(false)
  isPartnerDevelopment Boolean  @default(false)
  createdAt            DateTime @default(now())

  customers      Customer[]
  loyaltySetting LoyaltySetting?
}

model LoyaltySetting {
  id     Int  @id @default(autoincrement())
  shopId Int  @unique
  shop   Shop @relation(fields: [shopId], references: [id])

  signupBonusPoints         Int     @default(100)
  orderSpendAmount          Int     @default(100)
  orderSpendPoints          Int     @default(10)
  refundSpendAmount         Int     @default(100)
  refundSpendPoints         Int     @default(10)
  checkoutRedemptionEnabled Boolean @default(true)
  checkoutRewardLimit       Int     @default(10)
  preferredIntegration      String  @default("theme")
  redemptionRewards         String  @db.Text

  // Checkout UI Text Settings
  checkoutLoginMessage        String @default("Sign in to use loyalty points.") @db.VarChar(500)
  checkoutDescription         String @default("You have {coupon_amount} available {reward_label}") @db.VarChar(500)
  checkoutRewardPrompt        String @default("Choose a {reward_singular}") @db.VarChar(500)
  checkoutRedeemButtonText    String @default("Redeem") @db.VarChar(500)
  checkoutRedeemingText       String @default("Redeeming...") @db.VarChar(500)
  checkoutPointsLabel         String @default("Available points") @db.VarChar(500)
  checkoutSelectRewardMsg     String @default("Please select a reward.") @db.VarChar(500)
  checkoutNotEnoughPtsMsg     String @default("Not enough points for this reward.") @db.VarChar(500)
  checkoutDisabledMsg         String @default("Rewards redemption is disabled in checkout.") @db.VarChar(500)
  checkoutRedemptionTitle     String @default("Redeem your Points") @db.VarChar(500)
  checkoutGiftCardMsg         String @default("Gift card created: {rewardCode}") @db.VarChar(500)
  checkoutDiscountMsg         String @default("Discount code created: {rewardCode}. Points will be deducted after payment.") @db.VarChar(500)
  checkoutErrorMsg            String @default("Could not redeem points") @db.VarChar(500)
  checkoutLoadingMsg          String @default("Available points loading...") @db.VarChar(500)
  checkoutAvailableRewardsMsg String @default("{reward_count} available {reward_label}") @db.VarChar(500)

  // Customer Account UI Text Settings
  accountLoginMessage     String @default("Sign in to view loyalty points.") @db.VarChar(500)
  accountBalanceTitle     String @default("Loyalty balance") @db.VarChar(500)
  accountAvailableLabel   String @default("Available points") @db.VarChar(500)
  accountCurrentBalance   String @default("Current balance") @db.VarChar(500)
  accountLoadingText      String @default("Loading...") @db.VarChar(500)
  accountRedeemingText    String @default("Converting...") @db.VarChar(500)
  accountRedeemButtonText String @default("Convert to store credit") @db.VarChar(500)
  accountDisabledMsg      String @default("Store credit conversion is currently disabled.") @db.VarChar(500)
  accountNotEnoughPtsMsg  String @default("Earn {remaining_points} more points to convert this amount.") @db.VarChar(500)
  accountGiftCardMsg      String @default("Store credit added: ${amount}") @db.VarChar(500)
  accountErrorMsg         String @default("Could not convert points to store credit") @db.VarChar(500)
  accountConfigErrorMsg   String @default("Loyalty API URL is not configured.") @db.VarChar(500)

  // Iframe Widget UI Settings
  iframeEyebrow          String @db.Text
  iframeHeading          String @db.Text
  iframeLoggedOutMessage String @db.Text
  iframeLoginLabel       String @db.Text
  iframePointsTemplate   String @db.Text
  iframeRewardsHeading   String @db.Text
  iframeNoRewardsMessage String @db.Text
  iframeRedeemButtonText String @db.Text
  iframeAccentColor      String @default("#008060") @db.VarChar(20)
  iframeBackgroundColor  String @default("#ffffff") @db.VarChar(20)
  iframeForegroundColor  String @default("#202223") @db.VarChar(20)
  iframeBorderColor      String @default("#e3e5e8") @db.VarChar(20)
  iframeFontFamily       String @default("system") @db.VarChar(120)
  iframeFontSize         Int    @default(14)
  iframeCustomCss        String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id     Int  @id @default(autoincrement())
  shopId Int
  shop   Shop @relation(fields: [shopId], references: [id])

  shopifyCustomerId String
  name              String?
  email             String?
  loyaltyPoints     Int      @default(0)
  createdAt         DateTime @default(now())

  transactions       PointTransaction[]
  rewards            Reward[]
  rewardActivityLogs RewardActivityLog[]

  @@unique([shopId, shopifyCustomerId])
}

model PointTransaction {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  points          Int
  transactionType String
  reason          String?
  createdAt       DateTime @default(now())
}

model Reward {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  rewardCode      String  @unique
  discountAmount  Float
  rewardType      String  @default("discount")
  shopifyRewardId String?

  pointsUsed Int

  status String @default("active")

  expiresAt    DateTime?
  orderId      String?
  appliedAt    DateTime?
  failedReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs RewardActivityLog[]
}

model RewardActivityLog {
  id Int @id @default(autoincrement())

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  rewardId Int?
  reward   Reward? @relation(fields: [rewardId], references: [id])

  rewardCode   String?
  activityType String
  message      String? @db.Text
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([rewardId])
  @@index([rewardCode])
  @@index([activityType])
}

model WebhookLog {
  id        Int      @id @default(autoincrement())
  topic     String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}
