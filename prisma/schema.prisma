generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id         Int      @id @default(autoincrement())
  shopDomain String   @unique
  shopifyPlanName String?
  isShopifyPlus Boolean @default(false)
  isPartnerDevelopment Boolean @default(false)
  createdAt  DateTime @default(now())

  customers      Customer[]
  loyaltySetting LoyaltySetting?
}

model LoyaltySetting {
  id     Int  @id @default(autoincrement())
  shopId Int  @unique
  shop   Shop @relation(fields: [shopId], references: [id])

  signupBonusPoints         Int     @default(100)
  orderSpendAmount          Int     @default(100)
  orderSpendPoints          Int     @default(10)
  refundSpendAmount         Int     @default(100)
  refundSpendPoints         Int     @default(10)
  checkoutRedemptionEnabled Boolean @default(true)
  preferredIntegration      String  @default("theme")
  redemptionRewards         String  @default("[{\"points\":100,\"discount\":2},{\"points\":250,\"discount\":5},{\"points\":500,\"discount\":10}]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id     Int  @id @default(autoincrement())
  shopId Int
  shop   Shop @relation(fields: [shopId], references: [id])

  shopifyCustomerId String
  name              String?
  email             String?
  loyaltyPoints     Int      @default(0)
  createdAt         DateTime @default(now())

  transactions PointTransaction[]
  rewards      Reward[]
  rewardActivityLogs RewardActivityLog[]

  @@unique([shopId, shopifyCustomerId])
}

model PointTransaction {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  points          Int
  transactionType String
  reason          String?
  createdAt       DateTime @default(now())
}

model Reward {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  rewardCode     String @unique
  discountAmount Float
  rewardType     String @default("discount")
  shopifyRewardId String?

  pointsUsed Int

  status String @default("active")

  expiresAt DateTime?
  orderId   String?
  appliedAt DateTime?
  failedReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs RewardActivityLog[]
}

model RewardActivityLog {
  id Int @id @default(autoincrement())

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  rewardId Int?
  reward   Reward? @relation(fields: [rewardId], references: [id])

  rewardCode   String?
  activityType String
  message      String? @db.Text
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([rewardId])
  @@index([rewardCode])
  @@index([activityType])
}

model WebhookLog {
  id        Int      @id @default(autoincrement())
  topic     String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}
